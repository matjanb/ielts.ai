# ─────────────────────────────────────────────────────────
# ielts.ai — Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to client. Used only in server-side routes.
# Find in: Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe (for payments) ─────────────────────────────────
# Find these in: Stripe Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe product price IDs (create in Stripe dashboard)
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# Stripe webhook secret (from Stripe → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OpenAI (for AI feedback features) ────────────────────
OPENAI_API_KEY=sk-...
